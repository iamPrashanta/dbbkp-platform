# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dbbkp_panel

# Authentication
JWT_SECRET=dbbkp-super-secret-change-in-prod
JWT_EXPIRES=7d

# Worker Settings
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# API Settings
PORT=4000
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Pipeline isolation
PIPELINE_ISOLATION=docker
PIPELINE_DOCKER_IMAGE=node:20-bookworm
PIPELINE_DOCKER_MEMORY=1g
PIPELINE_DOCKER_CPUS=1
PIPELINE_DOCKER_NETWORK=bridge
PIPELINE_CONCURRENCY=2
